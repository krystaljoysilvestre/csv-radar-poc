# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/csv_radar_poc

# Logging
LOG_LEVEL=INFO

# Scraper Configuration
SCRAPER_TIMEOUT=30
SCRAPER_RETRIES=3
SCRAPER_BACKOFF_FACTOR=1.5

# Crawler Configuration
CRAWLER_TIMEOUT=60
CRAWLER_RETRIES=3
CRAWLER_BACKOFF_FACTOR=1.5

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_SECOND=2
RATE_LIMIT_BURST=5

# Playwright (if JS rendering needed)
BROWSER_TYPE=chromium
BROWSER_HEADLESS=true
POLICY_USE_PLAYWRIGHT=false

# News RSS feeds (comma-separated URLs). NEWS_FEEDS is preferred; NEWS_SOURCES remains supported.
NEWS_FEEDS=https://www.rappler.com/feeds/latest,https://feed.inquirer.net/latest,https://www.gmanetwork.com/news/feed/
NEWS_SOURCES=

# Policy Sources
DOE_BASE_URL=https://www.doe.gov.ph
ERC_BASE_URL=https://www.erc.gov.ph

# Testing
MOCK_RESPONSES=false
